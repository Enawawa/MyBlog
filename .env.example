# Upstash Redis credentials (get from https://console.upstash.com)
UPSTASH_REDIS_REST_URL=your_redis_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_redis_rest_token_here

# Search QA auth settings
SEARCH_JWT_SECRET=your_strong_random_secret_here
SEARCH_CLIENT_ID=myblog-web

# Frontend-exposed search config
NEXT_PUBLIC_SEARCH_CLIENT_ID=myblog-web
NEXT_PUBLIC_SEARCH_TOKEN_ENDPOINT=/api/auth/token
NEXT_PUBLIC_SEARCH_API_ENDPOINT=/api/search
